# =============================================================================
# Environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values. The literal
# "your-key-here" placeholders will fail Clerk's shape validation, so
# neither `npm run dev` nor `npm run build` will work until you replace them.
#
# Variables are grouped by when they are read:
#   * build-time — inlined by Next into the client bundle during `next build`.
#     Must be set BEFORE the build runs (CI, Docker, or your deploy platform's
#     build step). Missing them fails the production build.
#   * runtime   — read by the server on each request. Set in the deploy
#     platform's runtime env; missing values only affect the code path that
#     uses them.
#
# The Clerk keys below are required for BOTH `next dev` (startup) and
# `next build` (inlined). If you only see "build-time" and skip them
# when running locally, the dev server serves a broken sign-in redirect.
# =============================================================================


# ─── Required (build-time + dev startup) ────────────────────────────────────────
# Clerk's client SDK validates the publishable key during `next build` and on
# dev-server startup. A valid-shaped test key is enough for both; real keys
# come from https://dashboard.clerk.com → your app → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here


# ─── Required (runtime — server-only) ───────────────────────────────────────────
# Without this, server-side Clerk calls will fail. Get it at the same place
# as the publishable key above.
CLERK_SECRET_KEY=sk_test_your-key-here


# ─── Optional — reserved for your app code ──────────────────────────────────────
# The template defines this as a convention but does not read it directly.
# Set it when you need an absolute URL in your own code — email templates,
# metadata base URLs, OAuth callbacks you add, webhook targets, etc.
#   local:  http://localhost:3003
#   prod:   https://your-app.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3003


# ─── Optional — database (runtime) ──────────────────────────────────────────────
# The app boots without a database, but any Drizzle query will fail.
# DATABASE_URL is the Neon (or other Postgres) connection string.
# NEON_PROJECT_ID is only needed for the `npm run db:branch:*` CLI commands.
DATABASE_URL=
NEON_PROJECT_ID=


# ─── Optional — AI features (runtime) ───────────────────────────────────────────
# Only needed if you use the AI SDK in your app code.
OPENAI_API_KEY=
